{
  "name": "lab7-unified-automation",
  "version": "1.0.0",
  "description": "Lab 7 — unified project: unit + API + E2E (reuses lab3/lab4 code)",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "vitest run ; playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@vitest/ui": "^3.0.5",
    "express": "^4.21.2",
    "supertest": "^7.0.0",
    "vitest": "^3.0.5"
  }
}
